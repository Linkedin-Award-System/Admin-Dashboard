# Environment Configuration
# This file contains environment-specific settings for the LinkedIn Awards Admin Dashboard
# Copy this file to .env.development for local development or .env.production for production

# Environment (development, staging, production)
VITE_APP_ENV=development

# API Configuration
# Development: http://localhost:4000/api
# Production: https://linkedin-creative-awards-api-production.up.railway.app/api
VITE_API_BASE_URL=http://localhost:4000/api

# API Timeout (in milliseconds)
VITE_API_TIMEOUT=30000

# API Retry Configuration
VITE_API_MAX_RETRIES=3

# React Query Configuration
VITE_QUERY_STALE_TIME=30000
VITE_QUERY_CACHE_TIME=300000

# Feature Flags (optional)
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG_MODE=false

# Admin Credentials (for reference only - DO NOT commit real credentials)
# Default admin: admin@example.com / ChangeMe123!

# Database Configuration (for reference - backend only)
# These are not used by the frontend but documented here for reference
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=linkedin_awards_db
# DB_USER=root
# DB_PASSWORD=admin
